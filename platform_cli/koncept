#!/usr/bin/env nu

# Safe wrapper for kcl run — exits with clear error on failure
def kcl_run [file: string, ...args: string] -> string {
    let result = (^kcl run $file ...$args | complete)
    if $result.exit_code != 0 {
        print $"❌ KCL compilation failed for ($file):"
        print $result.stderr
        exit 1
    }
    $result.stdout
}

# Resolve builder filename — uses koncept.yaml config if present, otherwise convention
def resolve_builder [factory_dir: string, builder_key: string, default_name: string] -> string {
    let config_path = $"($factory_dir)/koncept.yaml"
    if ($config_path | path exists) {
        let config = (open $config_path)
        if ($config | get -i builders | get -i $builder_key) != null {
            $config.builders | get $builder_key
        } else {
            $default_name
        }
    } else {
        $default_name
    }
}

# Check if factory uses the generic render.k pattern
def has_render_k [factory_dir: string] -> bool {
    ($"($factory_dir)/render.k" | path exists)
}

def main [
  command: string
  render_type?: string
  --factory: string  # Optional: default is 'factory'
  --output: string
] {
  let cwd = $env.PWD
  let base = ($cwd | path basename)
  let app = ($cwd | path dirname | path basename)
  let koncept_dir = ($env.FILE_PWD)

  let factory_dir = (if $factory != null { $factory } else { "factory" })

  match $command {
    "validate" => {
      print "[Validate] Checking factory configuration..."
      let seed_file = (resolve_builder $factory_dir "seed" "factory_seed.k")
      let result = (^kcl run $"($factory_dir)/($seed_file)" | complete)
      if $result.exit_code != 0 {
          print $"❌ Validation failed:\n($result.stderr)"
          exit 1
      }
      print "✅ Configuration is valid"
    }

    "init" => {
      # Scaffold a new factory directory with render.k + factory_seed.k template
      let target_dir = (if $factory != null { $factory } else { "factory" })
      let framework_render = ($koncept_dir | path join "../../framework/factory/render.k")

      if ($"($target_dir)/render.k" | path exists) {
          print $"❌ Factory already exists at ($target_dir)/render.k"
          exit 1
      }

      print $"[Init] Scaffolding factory at ($target_dir)/"
      mkdir $target_dir

      # Copy render.k from framework
      if ($framework_render | path exists) {
          cp $framework_render $"($target_dir)/render.k"
          print "  ✅ render.k copied from framework"
      } else {
          print $"  ⚠️ render.k not found at ($framework_render) — create manually"
      }

      # Generate factory_seed.k template
      let seed_content = [
          '"""'
          'Factory seed — fills the render.k contract.'
          'Edit the imports and variables below for your environment.'
          ''
          'Contract exports: _stack, _project_name, _git_repo_url, _manifest_path'
          '"""'
          'import framework.models.manifests.renderstack'
          '# TODO: import your configurations module'
          '# import <project>.pre_releases.configurations_dev as config'
          ''
          '# TODO: set _base_stack from your configurations'
          '# _base_stack = config._stack'
          ''
          '# Full stack for rendering (standardized contract variable)'
          '# _stack = renderstack.RenderStack {'
          '#     instanceConfigurations = _base_stack.instanceConfigurations'
          '#     k8snamespaces = _base_stack.k8snamespaces'
          '#     components = _base_stack.components'
          '#     accessories = _base_stack.accessories'
          '# }'
          ''
          '# Standardized contract variables for render.k'
          '# _project_name = config._project.instance.name'
          '# _git_repo_url = config._pre_release_configurations.gitRepoUrl'
          '# _manifest_path = "projects/<project>/pre_releases/manifests/<env>/output"'
      ] | str join "\n"

      $seed_content | save -f $"($target_dir)/factory_seed.k"
      print "  ✅ factory_seed.k template created — edit with your project imports"
      print ""
      print "Next steps:"
      print $"  1. Edit ($target_dir)/factory_seed.k with your project imports"
      print $"  2. Run: koncept validate --factory ($target_dir)"
      print $"  3. Run: koncept render argocd --factory ($target_dir)"
    }

    "publish" => {
      # Publish a KCL module as OCI artifact
      if $render_type == null {
          print "❌ Missing module path. Usage: koncept publish <module_path> --output <version>"
          print "   Example: koncept publish framework --output 1.0.0"
          exit 1
      }
      let module_path = $render_type
      let version = (if $output != null { $output } else {
          print "❌ Missing version. Usage: koncept publish <module_path> --output <version>"
          exit 1
      })
      print $"[Publish] Pushing ($module_path) as OCI artifact v($version)..."
      let result = (^kcl mod push $"oci://($module_path):($version)" | complete)
      if $result.exit_code != 0 {
          print $"❌ Publish failed:\n($result.stderr)"
          exit 1
      }
      print $"✅ Published ($module_path):($version)"
    }

    "render" => {
      if $render_type == null {
          print "❌ Missing render type. Usage: koncept render <argocd|helmfile|kusion|kustomize>"
          exit 1
      }

      # New pattern: generic render.k with -D output=TYPE
      if (has_render_k $factory_dir) {
        let render_file = $"($factory_dir)/render.k"

        match $render_type {
          "argocd" => {
            let output_dir = (if $output != null { $output } else { $"../../../generated/($base)/($app)" })
            let output_path = ($output_dir | path expand)
            let manifest_path = $"($output_path)/kubernetes_manifests.yaml"
            print $"[ArgoCD] Generating manifests for app=($app) in env=($base)..."
            mkdir $output_path
            kcl_run $render_file -D "output=yaml" -o $manifest_path
          }

          "helmfile" => {
            let output_dir = (if $output != null { $output } else { "output" })
            let templates_src = ($koncept_dir | path join "../../framework/templates/helm")

            print "[Helmfile] Generating parameterized Helm charts (Strategy B)..."

            let charts_data = (kcl_run $render_file -D "output=helm" | from yaml -a)

            for entry in $charts_data {
                let chart_name = $entry.chart.name
                let chart_dir = $"($output_dir)/charts/($chart_name)"

                mkdir $chart_dir
                $entry.chart | to yaml | save -f $"($chart_dir)/Chart.yaml"
                $entry.values | to yaml | save -f $"($chart_dir)/values.yaml"

                let templates_dir = $"($chart_dir)/templates"
                mkdir $templates_dir
                glob $"($templates_src)/*" | each {|f| cp $f $templates_dir }

                print $"  [Chart] ($chart_name) -> ($chart_dir)"
            }

            kcl_run $render_file -D "output=helmfile" -o $"($output_dir)/helmfile.yaml"
            print "[Helmfile] Done."
          }

          "kusion" => {
            let output_path = (if $output != null { $output } else { "output" })
            let output_file = $"($output_path)/kusion_spec.yaml"
            print $"[Kusion] Running KCL for app=($app), env=($base) -> ($output_file)..."
            mkdir $output_path
            kcl_run $render_file -D "output=yaml" -o $output_file
          }

          "kustomize" => {
            let output_dir = (if $output != null { $output } else { "output" })
            let base_dir = $"($output_dir)/base"
            print $"[Kustomize] Generating base manifests and kustomization.yaml..."
            mkdir $base_dir

            # Generate kustomization.yaml
            kcl_run $render_file -D "output=kustomize" -o $"($base_dir)/kustomization.yaml"

            # Generate individual manifest files
            let manifests = (kcl_run $render_file -D "output=yaml" | from yaml -a)
            for m in $manifests {
                let kind = ($m.kind | str downcase)
                let name = $m.metadata.name
                let filename = $"($kind)-($name).yaml"
                $m | to yaml | save -f $"($base_dir)/($filename)"
                print $"  [Resource] ($filename)"
            }
            print "[Kustomize] Done."
          }

          _ => {
            print $"❌ Unsupported render type: ($render_type). Use: argocd, helmfile, kusion, kustomize"
            exit 1
          }
        }
      } else {
        # Legacy pattern: per-builder files
        match $render_type {
          "argocd" => {
            let output_dir = (if $output != null { $output } else { $"../../../generated/($base)/($app)" })
            let output_path = ($output_dir | path expand)
            let builder = (resolve_builder $factory_dir "yaml" "yaml_builder.k")
            let manifest_path = $"($output_path)/kubernetes_manifests.yaml"
            print $"[ArgoCD] Generating manifests for app=($app) in env=($base)..."
            mkdir $output_path
            kcl_run $"($factory_dir)/($builder)" -o $manifest_path
          }

          "helmfile" => {
            let output_dir = (if $output != null { $output } else { "output" })
            let templates_src = ($koncept_dir | path join "../../framework/templates/helm")
            let chart_builder = (resolve_builder $factory_dir "chart_values" "chart_values_builder.k")
            let hf_builder = (resolve_builder $factory_dir "helmfile" "helmfile_builder.k")

            print "[Helmfile] Generating parameterized Helm charts (Strategy B)..."

            let charts_data = (kcl_run $"($factory_dir)/($chart_builder)" | from yaml -a)

            for entry in $charts_data {
                let chart_name = $entry.chart.name
                let chart_dir = $"($output_dir)/charts/($chart_name)"

                mkdir $chart_dir
                $entry.chart | to yaml | save -f $"($chart_dir)/Chart.yaml"
                $entry.values | to yaml | save -f $"($chart_dir)/values.yaml"

                let templates_dir = $"($chart_dir)/templates"
                mkdir $templates_dir
                glob $"($templates_src)/*" | each {|f| cp $f $templates_dir }

                print $"  [Chart] ($chart_name) -> ($chart_dir)"
            }

            kcl_run $"($factory_dir)/($hf_builder)" -o $"($output_dir)/helmfile.yaml"
            print "[Helmfile] Done."
          }

          "kusion" => {
            let output_path = (if $output != null { $output } else { "output" })
            let builder = (resolve_builder $factory_dir "kusion" "main.k")
            let output_file = $"($output_path)/kusion_spec.yaml"
            print $"[Kusion] Running KCL for app=($app), env=($base) -> ($output_file)..."
            mkdir $output_path
            kcl_run $"($factory_dir)/($builder)" -o $output_file
          }

          _ => {
            print $"❌ Unsupported render type: ($render_type). Use: argocd, helmfile, kusion, kustomize"
            exit 1
          }
        }
      }
    }

    _ => {
      print $"❌ Unknown command: ($command). Use: init, render, validate, publish"
      exit 1
    }
  }
}
